# AgentFlow-Eval 服务器部署环境变量
# 复制为 backend/.env 后按需修改（docker compose 从 backend/ 目录读取）

# ---- 运行模式 ----
ENV=prod
DEBUG=false
SECRET_KEY=请替换为随机长字符串

# ---- CORS（填你的域名或服务器 IP）----
# 若仅通过 Nginx 同源访问（前端 80 反代 /api），可保留 localhost
CORS_ORIGINS=["http://localhost","http://YOUR_SERVER_IP","https://YOUR_DOMAIN"]

# ---- PostgreSQL（docker-compose 内网服务名）----
POSTGRES_USER=agentflow
POSTGRES_PASSWORD=请替换为强密码
POSTGRES_DB=agentflow_eval
DATABASE_URL=postgresql+asyncpg://agentflow:请替换为强密码@postgres:5432/agentflow_eval

# ---- Redis / Celery（生产必须 eager=false）----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# ---- OpenAI（评测必填）----
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ---- 日志 / 限流 ----
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ---- 鉴权（生产建议开启）----
AUTH_ENABLED=false
API_KEYS=
TENANCY_ENABLED=false
ADMIN_ACTORS=admin

# ---- Flower 监控（docker-compose 内 basic-auth）----
FLOWER_USER=admin
FLOWER_PASSWORD=请替换为强密码
